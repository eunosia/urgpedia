---
/**
 * DkaCalculator — Calculadora de apoyo para cetoacidosis diabética (DKA).
 *
 * Componente reutilizable (vive en el repo del SITIO). Usa el shell común
 * `calculator.css`; la lógica clínica (campos + fórmulas) es propia y explícita
 * para poder revisarse de forma aislada. Se embebe en una página de contenido:
 *
 *   import DkaCalculator from '@/components/calculators/DkaCalculator.astro';
 *   <DkaCalculator />
 *
 * ⚠️ PILOTO — VALIDACIÓN CLÍNICA PENDIENTE: las fórmulas y umbrales (sodio
 * corregido de Katz, anion gap, osmolalidad efectiva, severidad ADA) son de
 * referencia y DEBEN ser validados por el mantenedor contra el protocolo local
 * antes de publicar. No asumir que son correctos.
 */
import './calculator.css';
---

<div class="calc not-content" data-calc="dka">
	<form class="calc-grid" novalidate>
		<label>
			Glucosa <span>(mg/dL)</span>
			<input type="number" inputmode="decimal" step="any" min="0" data-f="glucosa" />
		</label>
		<label>
			pH venoso
			<input type="number" inputmode="decimal" step="any" min="6" max="8" data-f="ph" />
		</label>
		<label>
			Bicarbonato HCO₃⁻ <span>(mEq/L)</span>
			<input type="number" inputmode="decimal" step="any" min="0" data-f="hco3" />
		</label>
		<label>
			Sodio Na⁺ <span>(mEq/L)</span>
			<input type="number" inputmode="decimal" step="any" min="0" data-f="na" />
		</label>
		<label>
			Cloro Cl⁻ <span>(mEq/L)</span>
			<input type="number" inputmode="decimal" step="any" min="0" data-f="cl" />
		</label>
	</form>

	<dl class="calc-out">
		<div><dt>Sodio corregido</dt><dd data-o="naCorr">—</dd></div>
		<div><dt>Anion gap</dt><dd data-o="ag">—</dd></div>
		<div><dt>Osmolalidad efectiva</dt><dd data-o="osm">—</dd></div>
		<div><dt>Severidad (ADA)</dt><dd data-o="sev">—</dd></div>
	</dl>

	<p class="calc-note">
		Herramienta de apoyo a la decisión, no reemplaza el juicio clínico.
		Fórmulas de referencia (ADA); verificar contra el protocolo local.
	</p>
</div>

<script>
	// Lógica cliente. Se cablea cada instancia de DKA en la página por separado.
	function initDka(root: HTMLElement) {
		const field = (n: string) =>
			root.querySelector<HTMLInputElement>(`[data-f="${n}"]`);
		const out = (n: string) =>
			root.querySelector<HTMLElement>(`[data-o="${n}"]`);

		const num = (el: HTMLInputElement | null) => {
			const v = el ? parseFloat(el.value) : NaN;
			return Number.isFinite(v) ? v : null;
		};
		const fmt = (v: number, d = 1) =>
			v.toLocaleString('es', { minimumFractionDigits: d, maximumFractionDigits: d });

		function recompute() {
			const glucosa = num(field('glucosa'));
			const ph = num(field('ph'));
			const hco3 = num(field('hco3'));
			const na = num(field('na'));
			const cl = num(field('cl'));

			// Sodio corregido (Katz): Na + 1.6 * ((glucosa - 100) / 100)
			const naCorrEl = out('naCorr');
			if (naCorrEl)
				naCorrEl.textContent =
					na !== null && glucosa !== null
						? `${fmt(na + 1.6 * ((glucosa - 100) / 100))} mEq/L`
						: '—';

			// Anion gap: Na - (Cl + HCO3)
			const agEl = out('ag');
			if (agEl)
				agEl.textContent =
					na !== null && cl !== null && hco3 !== null
						? `${fmt(na - (cl + hco3))} mEq/L`
						: '—';

			// Osmolalidad efectiva: 2*Na + glucosa/18
			const osmEl = out('osm');
			if (osmEl)
				osmEl.textContent =
					na !== null && glucosa !== null
						? `${fmt(2 * na + glucosa / 18)} mOsm/kg`
						: '—';

			// Severidad DKA (ADA), por pH y HCO3. Se toma la categoría más grave
			// entre ambos criterios cuando difieren.
			const sevEl = out('sev');
			if (sevEl) {
				let sev: string | null = null;
				const rank = { leve: 1, moderada: 2, grave: 3 } as const;
				const level = { leve: 'low', moderada: 'mid', grave: 'high' } as const;
				const byPh =
					ph === null ? null : ph < 7.0 ? 'grave' : ph < 7.25 ? 'moderada' : ph <= 7.3 ? 'leve' : null;
				const byHco3 =
					hco3 === null ? null : hco3 < 10 ? 'grave' : hco3 < 15 ? 'moderada' : hco3 <= 18 ? 'leve' : null;
				for (const c of [byPh, byHco3]) {
					if (c && (!sev || rank[c as keyof typeof rank] > rank[sev as keyof typeof rank])) sev = c;
				}
				sevEl.textContent = sev ? sev[0].toUpperCase() + sev.slice(1) : '—';
				if (sev) sevEl.setAttribute('data-level', level[sev as keyof typeof level]);
				else sevEl.removeAttribute('data-level');
			}
		}

		root.addEventListener('input', recompute);
		recompute();
	}

	document.querySelectorAll<HTMLElement>('[data-calc="dka"]').forEach(initDka);
</script>
