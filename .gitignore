# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Node (si se usa para desarrollo local)
node_modules/

# Astro / Starlight (artefactos de build)
dist/
.astro/
.env.production

# Contenido de protocolos: se trae por fetch desde el repo de contenido
# (fuente de verdad) en cada build; NO se versiona en el repo del sitio.
.content-cache/
/src/content/docs/**
# Conservar el andamiaje versionado: directorios de secciones, sus .gitkeep
# y la portada provisional.
!/src/content/docs/**/
!/src/content/docs/index.mdx
!/src/content/docs/temas.mdx
!/src/content/docs/**/.gitkeep
# El blog de Novedades es del sitio (no contenido sincronizado): se versiona.
!/src/content/docs/blog/**

# Snapshot histórico de traspaso (no es parte del repo)
/estado_actual.md

# Backups locales
backups/
*.sql
*.dump

# Scripts con datos sensibles (PII, credenciales)
scripts/create-users-auth0.py
scripts/*-users-*.py
scripts/auth0-whitelist-action.js
scripts/auth0-link-accounts-action.js
*.csv
